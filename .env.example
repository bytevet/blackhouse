# Required — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Database password (shared between app and db containers)
POSTGRES_PASSWORD=blackhouse

# Admin password for initial seed (random if omitted, check server logs)
# ADMIN_PASSWORD=

# Public URL of the app (use :5173 for local dev, :3000 for docker compose)
BETTER_AUTH_URL=http://localhost:5173

# URL that agent containers use to reach this server
# Docker Desktop (macOS/Windows): http://host.docker.internal:3000
# Linux (Docker Engine): http://host.docker.internal:3000 (resolved via extra_hosts in compose.yml)
# Podman (macOS): http://host.containers.internal:3000
BLACKHOUSE_CONTAINER_URL=http://host.docker.internal:3000

# Docker socket path (override for Podman)
# Podman (macOS): /run/podman/podman.sock
# DOCKER_HOST_SOCKET=/var/run/docker.sock

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Local development (not used by docker compose)
# DATABASE_URL=postgresql://blackhouse:blackhouse@localhost:5432/blackhouse
