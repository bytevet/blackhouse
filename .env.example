# Database
DATABASE_URL=postgresql://blackhouse:blackhouse@localhost:5432/blackhouse

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# URL that agent containers use to reach this server.
# - Dev (Docker Desktop): http://host.docker.internal:3000 (default)
# - Docker Compose: http://blackhouse:3000 (use the app service name)
# - Production: https://your-domain.com
BLACKHOUSE_CONTAINER_URL=http://host.docker.internal:3000

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
