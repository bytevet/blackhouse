FROM ubuntu:24.04

ARG AGENT_TYPE=claude-code

ENV DEBIAN_FRONTEND=noninteractive

# Install base tools
RUN apt-get update && apt-get install -y \
    curl \
    git \
    wget \
    unzip \
    jq \
    openssh-client \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Python 3
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install coding agents based on AGENT_TYPE
RUN if [ "$AGENT_TYPE" = "claude-code" ]; then \
        npm install -g @anthropic-ai/claude-code; \
    fi

# Create workspace directory
RUN mkdir -p /workspace
WORKDIR /workspace

# Copy MCP result server
COPY src/mcp/result-server.ts /opt/blackhouse/result-server.ts
RUN cd /opt/blackhouse && npm init -y && npm install typescript @types/node \
    && npx tsc --target ES2022 --module nodenext --moduleResolution nodenext result-server.ts \
    || true

# Entrypoint script
COPY scripts/session-entrypoint.sh /opt/blackhouse/entrypoint.sh
RUN chmod +x /opt/blackhouse/entrypoint.sh

ENTRYPOINT ["/opt/blackhouse/entrypoint.sh"]
CMD ["sleep", "infinity"]
